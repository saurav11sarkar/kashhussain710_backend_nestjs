NODE_ENV=development
PORT=5000

# Optional: if Mongo is missing, check-car APIs can still boot
MONGO_URI=

# DVLA
DVLA_KEY_TYPE=free
DVLA_FREE_API_KEY=
DVLA_PAID_API_KEY=
DVLA_BASE_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles

# Backward-compatible legacy env names
FREE_DEVIAL_KEY=
PAID_DEVIAL_KEY=

# Auth / app
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=1h
ACCESS_TOKEN_SECRET=your_access_secret
ACCESS_TOKEN_EXPIRES=7d
REFRESH_TOKEN_SECRET=your_refresh_secret
REFRESH_TOKEN_EXPIRES=90d

FRONTEND_URL=http://localhost:3000
